@model lab1_AS.Models.Order

@{
    ViewData["Title"] = "Change Order Status";
}

<h1>Change Order Status</h1>

<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="EditStatus">
            <input type="hidden" asp-for="Id" />

            <div class="form-group mb-4">
                <label class="control-label mb-2">Select New Status</label>
                <select name="orderStatusId" class="form-control" asp-items="ViewBag.OrderStatusId"></select>
            </div>

            <div class="form-group">
                <input type="submit" value="Save Changes" class="btn btn-primary" />
                <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-secondary ms-2">Cancel</a>
            </div>
        </form>
    </div>
</div>