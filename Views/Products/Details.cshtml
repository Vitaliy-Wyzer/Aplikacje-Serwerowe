@model lab1_AS.Models.Product

@{
    ViewData["Title"] = "Details";
}

<h1>Product Details</h1>

<div>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">Name</dt>
        <dd class = "col-sm-10">@Html.DisplayFor(model => model.Name)</dd>

        <dt class = "col-sm-2">Price</dt>
        <dd class = "col-sm-10">@Html.DisplayFor(model => model.Price)</dd>

        <dt class = "col-sm-2">Category</dt>
        <dd class = "col-sm-10">@Html.DisplayFor(model => model.Category.Name)</dd>

        <dt class = "col-sm-2">Tags</dt>
        <dd class = "col-sm-10">
            @if (Model.Tags != null && Model.Tags.Any())
            {
                foreach (var tag in Model.Tags)
                {
                    <a asp-action="ByTag" asp-route-tagId="@tag.Id" class="badge bg-primary text-decoration-none">
                        @tag.Name
                    </a> <span> </span>
                }
            }
            else
            {
                <span class="text-muted">No tags assigned.</span>
            }
        </dd>
    </dl>
</div>
<div>
    <a asp-action="Edit" asp-route-id="@Model?.Id">Edit</a> |
    <a asp-action="Index">Back to List</a>
</div>